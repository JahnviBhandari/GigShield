# ============================================================
#  GigShield Frontend — Environment Variables (Vite)
#  Copy this file to .env and fill in your values.
#  Variables MUST be prefixed with VITE_ to be exposed to the browser.
# ============================================================

# Backend API URL (your Node.js server)
VITE_API_URL=https://gigshield-backend-m61a.onrender.com

# Firebase (optional — only if you use Firebase features)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
